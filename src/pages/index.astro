---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactForm from '../components/ContactForm.astro';
import Terminal from '../components/Terminal.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!DOCTYPE html>
<html
    lang="en"
    x-data="{ darkMode: localStorage.getItem('dark') === 'true'} "
    x-init="$watch('darkMode', val => localStorage.setItem('dark', val))"
    x-bind:class="{ 'dark': darkMode }"
    class="scroll-smooth"
>
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body
        class="bg-gradient-to-br to-slate-300 from-slate-50 text-slate-800 dark:from-slate-900 dark:to-slate-700 dark:text-slate-50"
    >
        <div class="w-full">
            <Header />
            <main
                class="flex flex-col items-center mx-auto w-full max-w-[1000px]"
            >
                <section
                    class="flex flex-col gap-8 px-8 pt-24 w-full min-h-screen sm:gap-16 sm:pt-36 font-terminal"
                >
                    <h1
                        class="text-4xl font-bold leading-snug sm:text-5xl lg:text-6xl font-terminal"
                    >
                        <span class="mr-2">{'>'}</span>Jacob <span
                            class="sm:hidden"><br /></span
                        >Van Schenck <span
                            class="animate-flash bg-slate-800 dark:bg-slate-300"
                            >&nbsp;
                        </span>
                    </h1>
          <p class="font-sans">
            I am a full-stack software engineer focused on
            building scalable product platforms across backend
            architecture, public APIs, permissions, admin
            workflows, and polished user experiences. I turn
            complex product domains into reliable systems that
            are clear for teams to extend and useful for the
            people relying on them. Check out my&nbsp;

            
            <a
              class="inline-block font-bold text-violet-600 dark:text-amber-500 group"
              href="#overflow"
              aria-label="selected work"
            >
              selected work
              <span
                class="block mt-1 w-full h-1 bg-violet-600 transition-transform duration-100 origin-left scale-x-0 dark:bg-amber-500 group-hover:scale-x-100"
              >
              </span>
            </a>
            &nbsp;or my&nbsp;

            <a
              class="inline-block font-bold text-violet-600 dark:text-amber-500 group"
              href="#projects"
              aria-label="side projects"
            >
              side projects
              <span
                class="block mt-1 w-full h-1 bg-violet-600 transition-transform duration-100 origin-left scale-x-0 dark:bg-amber-500 group-hover:scale-x-100"
              >
              </span>
            </a>
          </p>
                    <Terminal />
                </section>
                <section
                    id="overflow"
                    class="flex flex-col gap-8 justify-center px-8 pt-16 w-full min-h-screen max-w-[1300px]"
                >
                    <h2 class="text-3xl font-black sm:text-5xl lg:text-5xl">
                        Overflow
                    </h2>
                    <div
                        class="grid overflow-hidden gap-8 p-6 rounded-2xl border transition-all duration-150 sm:p-8 border-slate-300 bg-slate-100/60 lg:grid-cols-[1fr_1fr] dark:border-slate-600 dark:bg-slate-800/50 dark:hover:border-amber-500/50 hover:border-violet-500/50"
                    >
                        <div class="flex flex-col gap-5 justify-center">
                            <p
                                class="text-sm font-bold text-violet-600 uppercase dark:text-amber-500 tracking-[0.2em]"
                            >
                                Full-Stack Platform Engineering
                            </p>
                            <h3
                                class="text-2xl font-black leading-tight sm:text-4xl text-slate-800 dark:text-slate-50"
                            >
                                Scaling nonprofit giving infrastructure across APIs, admin tooling, permissions, and donation workflows.
                            </h3>
                            <p class="text-slate-600 dark:text-slate-300">
                                I worked across Overflow's TypeScript monorepo,
                                contributing to backend architecture, public APIs,
                                donor-facing giving flows, nonprofit dashboard
                                workflows, location-aware permissions, funds,
                                reporting, reconciliation, and developer tooling.
                            </p>
                            <ul class="flex flex-wrap gap-2">
                                {
                                    [
                                        '286 commits',
                                        '233 tickets',
                                        '82k lines changed',
                                        'Public APIs',
                                        'Permissions',
                                    ].map((item) => (
                                        <li class="py-1 px-3 text-xs text-violet-800 rounded-3xl sm:text-sm bg-violet-300/40 dark:bg-amber-800/40 dark:text-amber-100/90">
                                            {item}
                                        </li>
                                    ))
                                }
                            </ul>
                            <a
                                href="/overflow/"
                                class="flex gap-2 items-center self-start font-bold text-violet-600 transition-all duration-150 dark:text-amber-500 group"
                            >
                                View case study
                                <span
                                    class="transition-transform duration-150 group-hover:translate-x-1"
                                    >{'->'}</span
                                >
                            </a>
                        </div>
                        <div
                            class="grid gap-3 p-4 rounded-xl border shadow-xl border-slate-300 bg-slate-950 text-slate-100 dark:border-slate-600"
                        >
                            <div class="flex gap-2 items-center text-xs text-slate-400">
                                <span class="w-3 h-3 bg-red-400 rounded-full"></span>
                                <span class="w-3 h-3 bg-amber-400 rounded-full"></span>
                                <span class="w-3 h-3 bg-emerald-400 rounded-full"></span>
                                <span class="ml-auto">Overflow / Platform</span>
                            </div>
                            <div class="grid gap-3 sm:grid-cols-2">
                                <div class="p-4 rounded-lg bg-slate-900">
                                    <p class="text-xs text-amber-300">API</p>
                                    <p class="mt-2 text-2xl font-black">Public</p>
                                    <p class="text-sm text-slate-400">donors · payments · campaigns</p>
                                </div>
                                <div class="p-4 rounded-lg bg-slate-900">
                                    <p class="text-xs text-violet-300">Access</p>
                                    <p class="mt-2 text-2xl font-black">Scoped</p>
                                    <p class="text-sm text-slate-400">locations · roles · exports</p>
                                </div>
                            </div>
                            <div class="grid gap-3 p-4 rounded-lg bg-slate-900">
                                <div class="flex justify-between items-center">
                                    <span class="text-sm text-slate-400">backend</span>
                                    <span class="text-2xl font-black">NestJS</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <span class="text-sm text-slate-400">frontend</span>
                                    <span class="text-2xl font-black">Next.js</span>
                                </div>
                                <p class="text-sm text-emerald-300">
                                    CQRS · domain events · queues · dashboard workflows
                                </p>
                            </div>
                        </div>
                    </div>
                </section>
                <section
                    id="bunches"
                    class="flex flex-col gap-8 justify-center px-8 pt-16 w-full min-h-screen max-w-[1300px]"
                >
                    <h2 class="text-3xl font-black sm:text-5xl lg:text-5xl">
                        Bunches
                    </h2>
                    <div
                        class="grid overflow-hidden gap-8 p-6 rounded-2xl border transition-all duration-150 sm:p-8 border-slate-300 bg-slate-100/60 lg:grid-cols-[1.1fr_0.9fr] dark:border-slate-600 dark:bg-slate-800/50 dark:hover:border-amber-500/50 hover:border-violet-500/50"
                    >
                        <div class="flex flex-col gap-5 justify-center">
                            <p
                                class="text-sm font-bold text-violet-600 uppercase dark:text-amber-500 tracking-[0.2em]"
                            >
                                Frontend Engineering
                            </p>
                            <h3
                                class="text-2xl font-black leading-tight sm:text-4xl text-slate-800 dark:text-slate-50"
                            >
                                Building the mobile-first social layer for sports
                                communities and onchain token-powered interactions.
                            </h3>
                            <p class="text-slate-600 dark:text-slate-300">
                                I was the primary engineer behind the Capacitor
                                Bunches client app and the REP token ecosystem,
                                spanning real-time chat, GraphQL, native mobile
                                flows, wallet UX, and gasless onchain actions.
                            </p>
                            <ul class="flex flex-wrap gap-2">
                                {
                                    [
                                        '485 app commits',
                                        'Real-time chat',
                                        'GraphQL platform',
                                        'Capacitor app',
                                        'REP token UX',
                                    ].map((item) => (
                                        <li class="py-1 px-3 text-xs text-violet-800 rounded-3xl sm:text-sm bg-violet-300/40 dark:bg-amber-800/40 dark:text-amber-100/90">
                                            {item}
                                        </li>
                                    ))
                                }
                            </ul>
                            <a
                                href="/bunches/"
                                class="flex gap-2 items-center self-start font-bold text-violet-600 transition-all duration-150 dark:text-amber-500 group"
                            >
                                View case study
                                <span
                                    class="transition-transform duration-150 group-hover:translate-x-1"
                                    >{'->'}</span
                                >
                            </a>
                        </div>
                        <div
                            class="grid gap-3 p-4 rounded-xl border shadow-xl border-slate-300 bg-slate-950 text-slate-100 dark:border-slate-600"
                        >
                            <div class="flex gap-2 items-center text-xs text-slate-400">
                                <span class="w-3 h-3 bg-red-400 rounded-full"></span>
                                <span class="w-3 h-3 bg-amber-400 rounded-full"></span>
                                <span class="w-3 h-3 bg-emerald-400 rounded-full"></span>
                                <span class="ml-auto">Bunches / Capacitor</span>
                            </div>
                            <div class="grid gap-3 sm:grid-cols-2">
                                <div class="p-4 rounded-lg bg-slate-900">
                                    <p class="text-xs text-amber-300">Realtime</p>
                                    <p class="mt-2 text-2xl font-black">Chat</p>
                                    <p class="text-sm text-slate-400">threads · reactions</p>
                                </div>
                                <div class="p-4 rounded-lg bg-slate-900">
                                    <p class="text-xs text-violet-300">REP</p>
                                    <p class="mt-2 text-2xl font-black">23B</p>
                                    <p class="text-sm text-slate-400">capped token system</p>
                                </div>
                            </div>
                            <div class="flex flex-col gap-3 p-4 rounded-lg bg-slate-900">
                                <div class="max-w-[85%] rounded-2xl rounded-bl-sm bg-violet-600 p-3 text-sm">
                                    New pick is live. Claim REP before kickoff.
                                </div>
                                <div
                                    class="self-end max-w-[85%] rounded-2xl rounded-br-sm bg-slate-700 p-3 text-sm"
                                >
                                    Shared to the bunch and pushed to mobile.
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
                <section
                    id="friends-on-chain"
                    class="flex flex-col gap-8 justify-center px-8 pt-16 w-full min-h-screen max-w-[1300px]"
                >
                    <h2 class="text-3xl font-black sm:text-5xl lg:text-5xl">
                        Friends on Chain
                    </h2>
                    <div
                        class="grid overflow-hidden gap-8 p-6 rounded-2xl border transition-all duration-150 sm:p-8 border-slate-300 bg-slate-100/60 lg:grid-cols-[0.95fr_1.05fr] dark:border-slate-600 dark:bg-slate-800/50 dark:hover:border-amber-500/50 hover:border-violet-500/50"
                    >
                        <div class="flex flex-col gap-5 justify-center">
                            <p
                                class="text-sm font-bold text-violet-600 uppercase dark:text-amber-500 tracking-[0.2em]"
                            >
                                Web3 Product Engineering
                            </p>
                            <h3
                                class="text-2xl font-black leading-tight sm:text-4xl text-slate-800 dark:text-slate-50"
                            >
                                Solo engineering a wallet-connected social NFT minting flow for Bunches.
                            </h3>
                            <p class="text-slate-600 dark:text-slate-300">
                                I built Friends on Chain end-to-end, spanning wallet
                                connection, friend identity entry, NFT preview
                                rendering, image generation, smart-contract minting,
                                backend upload, and share navigation.
                            </p>
                            <ul class="flex flex-wrap gap-2">
                                {
                                    [
                                        '318 commits',
                                        'Solo engineer',
                                        'NFT mint flow',
                                        'Wallet UX',
                                        'Image generation',
                                    ].map((item) => (
                                        <li class="py-1 px-3 text-xs text-violet-800 rounded-3xl sm:text-sm bg-violet-300/40 dark:bg-amber-800/40 dark:text-amber-100/90">
                                            {item}
                                        </li>
                                    ))
                                }
                            </ul>
                            <a
                                href="/friends-on-chain/"
                                class="flex gap-2 items-center self-start font-bold text-violet-600 transition-all duration-150 dark:text-amber-500 group"
                            >
                                View case study
                                <span
                                    class="transition-transform duration-150 group-hover:translate-x-1"
                                    >{'->'}</span
                                >
                            </a>
                        </div>
                        <a
                            href="/friends-on-chain/"
                            class="group relative overflow-hidden rounded-xl border shadow-xl border-slate-300 bg-white dark:border-slate-600 dark:bg-slate-950"
                            aria-label="View Friends on Chain case study"
                        >
                            <img
                                src="/friends-on-chain/friends-on-chain-share-desktop-1200.webp"
                                srcset="/friends-on-chain/friends-on-chain-share-desktop-1200.webp 1200w, /friends-on-chain/friends-on-chain-share-desktop-1800.webp 1800w"
                                sizes="(min-width: 1024px) 640px, calc(100vw - 112px)"
                                alt="Friends on Chain desktop sharing screen"
                                class="w-full transition-transform duration-300 group-hover:scale-[1.02]"
                                width="2990"
                                height="1788"
                                loading="lazy"
                            />
                            <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-950/80 to-transparent p-5 text-slate-50">
                                <p class="text-sm font-bold text-amber-300">
                                    Live Product Screens
                                </p>
                                <p class="mt-1 text-2xl font-black">
                                    Mint, preview, and share the final NFT result.
                                </p>
                            </div>
                        </a>
                    </div>
                </section>

                <section
                    id="projects"
                    class="flex flex-col justify-center pt-16 min-h-screen sm:gap-8 max-w-[1300px]"
                >
                    <h2
                        class="pl-8 text-3xl font-black sm:text-5xl lg:text-5xl"
                    >
                        Side Projects
                    </h2>
                    <div
                        class="flex flex-col transition-all duration-150 sm:gap-16"
                    >
            <ProjectCard
              imgSrc={'/TsunamiTrades.png'}
              techList={[
                'React',
                'TailwindCSS',
                'Solidity',
                'HardHat',
                'Viem',
              ]}
              projectTitle={'MyDex'}
              siteLink="https://dex-vs.netlify.app/"
              githubLink="https://github.com/jacobvanschenck/tsunami-trades"
              description="A web3 trading platform to create Market Orders and Limit Orders for ERC-20 coins."
            />
                        <ProjectCard
                            imgSrc={'/turbo-runners.png'}
                            techList={[
                                'Next.js',
                                'TailwindCSS',
                                'Solidity',
                                'HardHat',
                            ]}
                            projectTitle={'Turbo Runners'}
                            siteLink="https://turbo-runners.vercel.app/"
                            githubLink="https://github.com/jacobvanschenck/turbo-runners"
                            description="An NFT Minting site for an ERC-721a token. This NFT includes Whitelisting address for early minting, Royalties on mint and transfer, and delayed art reveal dates."
                        />
                        
                    </div>
                </section>
                <section
                    id="connect"
                    class="flex items-center px-8 w-full min-h-screen max-w-[1300px]"
                >
                    <div class="flex flex-col gap-12">
                        <h2 class="text-3xl font-black sm:text-5xl">
                            Let's Connect
                        </h2>
                        <p class="w-full text-slate-500">
                            Feel free to reach out and I will get back to you as
                            soon as I can.
                        </p>
                        <ContactForm />
                    </div>
                </section>
            </main>
            <Footer />
        </div>
    </body>
</html>
